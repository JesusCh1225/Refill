generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── 사용자 ──────────────────────────────────────────────────────────────

model User {
  id                 Int      @id @default(autoincrement())
  email              String?  @unique @db.VarChar(255)
  name               String   @db.VarChar(50)
  nickname           String?  @db.VarChar(50)
  phone              String?  @db.VarChar(20)
  avatarUrl          String?  @db.VarChar(500)
  bio                String?  @db.Text
  contact            String?  @db.VarChar(200)
  representativeSong String?  @db.VarChar(500)
  licenses           String?  @db.Text
  career             String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  oauthAccounts        OAuthAccount[]
  posts                Post[]
  comments             Comment[]
  likes                Like[]
  bookmarks            Bookmark[]
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")
  reviewsGiven         Review[]           @relation("ReviewsGiven")
  reviewsReceived      Review[]           @relation("ReviewsReceived")
  notifications        Notification[]     @relation("NotificationsReceived")
  actedNotifications   Notification[]     @relation("NotificationsSent")
  reports              Report[]
  communityPosts       CommunityPost[]
  communityComments    CommunityComment[]
  communityLikes       CommunityLike[]
  blockedUsers         UserBlock[]        @relation("BlockedBy")
  blockedByUsers       UserBlock[]        @relation("Blocking")
  conversationsLeft    ConversationLeft[] @relation("LeftByMe")
  conversationPartners ConversationLeft[] @relation("LeftByPartner")
}

// ── OAuth 계정 연동 ──────────────────────────────────────────────────────

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String   @db.VarChar(20)   // "kakao" | "naver"
  providerAccountId String   @db.VarChar(100)
  accessToken       String?  @db.Text
  refreshToken      String?  @db.Text
  expiresAt         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ── 카테고리 ─────────────────────────────────────────────────────────────

model Category {
  id    Int    @id @default(autoincrement())
  slug  String @unique @db.VarChar(50) // "lesson", "guitar"
  name  String @db.VarChar(50)         // "레슨", "기타/베이스"

  postCategories PostCategory[]
}

// ── 해시태그 ─────────────────────────────────────────────────────────────

model Hashtag {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  posts PostHashtag[]
}

model PostHashtag {
  postId    Int
  hashtagId Int

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
}

// ── 게시글 ────────────────────────────────────────────────────────────────

enum PriceType {
  FREE        // 무료
  MONTHLY     // 월정액
  YEARLY      // 년
  PER_SESSION // 회당
  NEGOTIABLE  // 협의
}

enum PostStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum PostDirection {
  OFFER // 합니다 / 팝니다
  SEEK  // 구합니다 / 삽니다
}

model Post {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(100)
  description  String?       @db.Text
  priceType    PriceType     @default(NEGOTIABLE)
  priceAmount  Int?                               // 원 단위 숫자 (무료/협의면 null)
  priceDisplay String        @db.VarChar(100)     // 표시용 "월 120,000원"
  imageEmoji   String        @db.VarChar(10)
  location     String        @db.VarChar(100)     // 표시용 "마포구"
  lat          Float?
  lng          Float?
  direction    PostDirection @default(OFFER)
  status       PostStatus    @default(PUBLISHED)
  viewCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categories   PostCategory[]
  images       PostImage[]
  locationTags PostLocationTag[]
  hashtags     PostHashtag[]
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  messages      Message[]
  reviews       Review[]
  notifications Notification[]
  reports       Report[]

  @@index([status, createdAt])
  @@index([authorId])
}

// ── 게시글 ↔ 카테고리 (N:M) ──────────────────────────────────────────────

model PostCategory {
  postId     Int
  categoryId Int

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
}

// ── 게시글 이미지 ─────────────────────────────────────────────────────────

model PostImage {
  id     Int    @id @default(autoincrement())
  postId Int
  url    String @db.VarChar(500)
  order  Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ── 게시글 지역 태그 (검색용) ──────────────────────────────────────────────

model PostLocationTag {
  id     Int    @id @default(autoincrement())
  postId Int
  tag    String @db.VarChar(50) // "마포", "홍대", "서울"

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tag])
}

// ── 댓글 ──────────────────────────────────────────────────────────────────

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  guestName String?  @db.VarChar(50)
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId   Int
  authorId Int?
  parentId Int?  // null = 최상위 댓글, non-null = 대댓글

  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([parentId])
}

// ── 좋아요 ────────────────────────────────────────────────────────────────

model Like {
  createdAt DateTime @default(now())

  userId Int
  postId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

// ── 북마크 ────────────────────────────────────────────────────────────────

model Bookmark {
  createdAt DateTime @default(now())

  userId Int
  postId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

// ── 리뷰/평점 ─────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int      // 1–5
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewerId Int
  revieweeId Int
  postId     Int? // 어떤 글에서 소통했는지

  reviewer User  @relation("ReviewsGiven",    fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User  @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [postId],  references: [id],     onDelete: SetNull)

  @@unique([reviewerId, revieweeId, postId])
}

// ── 메시지 ────────────────────────────────────────────────────────────────

model Message {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId   Int
  receiverId Int
  postId     Int? // 어떤 글에 대한 문의인지 (선택)

  sender   User  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User  @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [postId], references: [id])

  @@index([receiverId, isRead])
}

// ── 알림 ──────────────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int                           // 수신자
  actorId   Int                           // 발생자 (댓글 작성자 등)
  type      String   @db.VarChar(20)      // COMMENT | REPLY
  postId    Int?
  commentId Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User  @relation("NotificationsReceived", fields: [userId],  references: [id], onDelete: Cascade)
  actor   User  @relation("NotificationsSent",     fields: [actorId], references: [id], onDelete: Cascade)
  post    Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ── 커뮤니티 게시글 ───────────────────────────────────────────────────────

model CommunityPost {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(200)
  category  String   @db.VarChar(20)  // "자유" | "문의"
  content   String   @db.Text
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments CommunityComment[]
  likes    CommunityLike[]
  reports  Report[]

  @@index([createdAt])
  @@index([category])
  @@index([authorId])
}

model CommunityComment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  authorId  Int
  postId    Int
  parentId  Int?
  createdAt DateTime @default(now())

  author  User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post    CommunityPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  CommunityComment?  @relation("CommunityReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies CommunityComment[] @relation("CommunityReplies")

  @@index([postId])
}

model CommunityLike {
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

// ── 사용자 차단 ───────────────────────────────────────────────────────────

model UserBlock {
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())

  blocker User @relation("BlockedBy", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocking",  fields: [blockedId],  references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ── 채팅방 나가기 ─────────────────────────────────────────────────────────

model ConversationLeft {
  userId    Int
  partnerId Int
  leftAt    DateTime @default(now())

  user    User @relation("LeftByMe",      fields: [userId],    references: [id], onDelete: Cascade)
  partner User @relation("LeftByPartner", fields: [partnerId], references: [id], onDelete: Cascade)

  @@id([userId, partnerId])
  @@index([userId])
}

// ── 신고 ──────────────────────────────────────────────────────────────────

model Report {
  id              Int      @id @default(autoincrement())
  reporterId      Int
  postId          Int?
  communityPostId Int?
  reason          String   @db.VarChar(200)
  status          String   @default("PENDING") @db.VarChar(20)
  createdAt       DateTime @default(now())

  reporter      User           @relation(fields: [reporterId],      references: [id], onDelete: Cascade)
  post          Post?          @relation(fields: [postId],          references: [id], onDelete: Cascade)
  communityPost CommunityPost? @relation(fields: [communityPostId], references: [id], onDelete: Cascade)

  @@index([status])
}
